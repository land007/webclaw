<!DOCTYPE Menu PUBLIC "-//freedesktop//DTD Menu 1.0//EN"
 "http://www.freedesktop.org/standards/menu-spec/1.0/menu.dtd">

<!-- Merge file to add AI Tools submenu -->
<Menu>
  <Name>Applications</Name>

  <!-- AI Tools submenu -->
  <Menu>
    <Name>AI Tools</Name>
    <Directory>ai-tools.directory</Directory>
    <Include>
      <Category>AITools</Category>
    </Include>
    <Layout>
      <Filename>openclaw.desktop</Filename>
      <Filename>hermes.desktop</Filename>
      <Separator/>
      <Filename>antigravity.desktop</Filename>
      <Filename>cursor.desktop</Filename>
      <Filename>trae.desktop</Filename>
      <Separator/>
      <Filename>claude-code.desktop</Filename>
      <Filename>codex-cli.desktop</Filename>
      <Filename>gemini-cli.desktop</Filename>
      <Filename>opencode-cli.desktop</Filename>
      <Separator/>
      <Merge type="all"/>
    </Layout>
  </Menu>
</Menu>
