# 按需安装专用 sudoers 片段
# 只允许 ubuntu 用户对调度脚本下载到固定前缀的 .deb 执行 apt-get install,
# 不影响全局 sudo 策略(即便 startup.sh 在设置 PASSWORD 时移除了全局 NOPASSWD)

# github_release 模式: 固定路径前缀的 .deb (OpenTypeless / CC Switch 等)
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y /tmp/webclaw-ondemand-*.deb

# 卸载模式: 由受控脚本读取 manifest 并只删除对应应用的受管安装目录或包
ubuntu ALL=(root) NOPASSWD: /usr/local/bin/webclaw-app-uninstaller *

# 日志准备: 避免 /tmp 下残留 root-owned 日志导致桌面用户无法写入
ubuntu ALL=(root) NOPASSWD: /usr/local/bin/webclaw-log-prepare *

# apt 模式: 刷新索引(每个 apt 应用安装前都需要)
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get update

# debconf 预配置（用于 Wireshark 等需要非交互安装的包）
ubuntu ALL=(root) NOPASSWD: /usr/bin/debconf-set-selections

# apt 模式: 显式列出每个允许按需安装的包名(避免通配符放权)
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y code
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y wireshark
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y flameshot
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y antigravity
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y gimp
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y blender
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y audacity

# 预安装脚本权限（用于 Antigravity 等需要先配置仓库的应用）
ubuntu ALL=(root) NOPASSWD: /usr/local/bin/install-antigravity
ubuntu ALL=(root) NOPASSWD: /bin/env * /opt/install-hermes.sh
ubuntu ALL=(root) NOPASSWD: /opt/install-hermes.sh
ubuntu ALL=(root) NOPASSWD: /bin/env * /opt/uninstall-hermes.sh
ubuntu ALL=(root) NOPASSWD: /opt/uninstall-hermes.sh
ubuntu ALL=(root) NOPASSWD: /usr/bin/gpg --dearmor -o /etc/apt/keyrings/*
ubuntu ALL=(root) NOPASSWD: /bin/tee /etc/apt/sources.list.d/*
ubuntu ALL=(root) NOPASSWD: /bin/chmod +x /etc/apt/keyrings/*

# 应用安装后置钩子: root-side 脚本按 app_id 分发执行预定义动作
# (Wireshark 建组+setcap 等). 命令参数硬编码在脚本内,避免 sudoers 解析 setcap
# 参数中的 = 时把它误判为 env 赋值导致规则不匹配。
ubuntu ALL=(root) NOPASSWD: /usr/local/bin/webclaw-app-postinstall *

# appimage 模式: 创建目录、嵌套移动解压内容 (Ghostty / Obsidian 等)
# AppImage 解压后内容嵌套放进 /opt/ondemand-apps/<id>/AppDir/,
# 让 manifest 里的 binary 路径形如 /opt/ondemand-apps/<id>/AppDir/bin/<bin> 自然成立。
# pkgforge 系列 AppImage (如 Ghostty) 解压出 /tmp/AppDir,
# 标准 AppImage 解压出 /tmp/squashfs-root,两种都允许。
ubuntu ALL=(root) NOPASSWD: /bin/mkdir -p /opt/ondemand-apps
ubuntu ALL=(root) NOPASSWD: /bin/mkdir -p /opt/ondemand-apps/*
ubuntu ALL=(root) NOPASSWD: /bin/mv -f /tmp/AppDir /opt/ondemand-apps/*/AppDir
ubuntu ALL=(root) NOPASSWD: /bin/mv -f /tmp/squashfs-root /opt/ondemand-apps/*/AppDir

# r2_download / direct_download 模式: 安装到 /opt/<app-id> (WebClaw Launcher / Cursor 等)
ubuntu ALL=(root) NOPASSWD: /bin/mkdir -p /opt/*
ubuntu ALL=(root) NOPASSWD: /bin/mv -f /tmp/*-extract-*/* /opt/*/*
ubuntu ALL=(root) NOPASSWD: /bin/cp -a /tmp/*-extract-*/*/. /opt/*/
ubuntu ALL=(root) NOPASSWD: /bin/mv -f /tmp/squashfs-root /opt/*/AppDir
ubuntu ALL=(root) NOPASSWD: /bin/mv -f /tmp/*-wrapper.sh /opt/*/*
ubuntu ALL=(root) NOPASSWD: /bin/chmod +x /opt/*/*
ubuntu ALL=(root) NOPASSWD: /bin/mv -f /tmp/*.desktop /usr/share/applications/

# Hermes Agent 专用：Python 包、Git、Supervisor（为 custom_script 安装方法提供支持）
ubuntu ALL=(root) NOPASSWD: /usr/bin/apt-get install -y python3-venv python3-pip git curl software-properties-common python3.11 python3.11-venv
ubuntu ALL=(root) NOPASSWD: /usr/bin/git
ubuntu ALL=(root) NOPASSWD: /bin/chown
ubuntu ALL=(root) NOPASSWD: /usr/bin/supervisorctl *
