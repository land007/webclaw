# ─────────────────────────────────────────────────────────────
#  Full CLI layer: adds Gemini, Codex, Cursor CLI
#  on top of land007/webclaw image
# ─────────────────────────────────────────────────────────────
ARG WEBCLAW_IMAGE=ghcr.io/land007/webclaw
ARG WEBCLAW_IMAGE_TAG=latest
FROM ${WEBCLAW_IMAGE}:${WEBCLAW_IMAGE_TAG}

LABEL org.opencontainers.image.title="webclaw_full" \
      org.opencontainers.image.description="WebClaw with additional advanced CLIs (Gemini + Codex + Cursor + OpenCode AI)" \
      org.opencontainers.image.source="https://github.com/land007/webclaw"

ENV WEBCODE_HAS_VIBE_KANBAN=true
ENV WEBCODE_HAS_CLAUDECODEUI=true

COPY configs/supervisord-full.conf /etc/supervisor/supervisord.conf
COPY configs/supervisor-vibe-kanban.conf /etc/supervisor/conf.d/supervisor-vibe-kanban.conf
COPY configs/supervisor-claudecodeui.conf /etc/supervisor/conf.d/supervisor-claudecodeui.conf

# full 镜像专属桌面图标(vibe-kanban 等服务在 webclaw 镜像不启用,所以图标也不出现)
COPY configs/desktop-shortcuts-full/ /opt/desktop-shortcuts/

# ─── AI Desktop Tools: Cursor CLI, Obsidian ─────────────────────────────
# (npm-based AI CLI tools moved to Dockerfile.base)

# Install Cursor CLI (cursor-agent) - direct binary download
RUN su -l ubuntu -c \
    'mkdir -p ~/.local/bin && \
     cd /tmp && \
     ARCH=$(dpkg --print-architecture) && \
     if [ "$ARCH" = "amd64" ]; then \
         curl -fsSL "https://api2.cursor.sh/updates/download-latest?os=cli-alpine-x64" -o cursor-cli.tar.gz; \
     else \
         curl -fsSL "https://api2.cursor.sh/updates/download-latest?os=cli-alpine-arm64" -o cursor-cli.tar.gz; \
     fi && \
     tar -xvf cursor-cli.tar.gz && \
     chmod +x cursor && \
     mv cursor ~/.local/bin/ && \
     rm cursor-cli.tar.gz'

# Obsidian 由 preinstall-on-demand.sh 统一处理(装到 /opt/ondemand-apps/obsidian/AppDir,
# 与 configs/on-demand-apps/obsidian.json 的 binary 路径一致)。

# ─── 5c. Pre-install Vibe Kanban globally ────────────────────────────────
RUN npm install -g --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000 --fetch-timeout=300000 vibe-kanban@0.1.8

# ─── 5d. Pre-install claudecodeui globally (CLI UI for lite mode support) ─
# This package requires native compilation (node-pty), takes time to build
RUN npm install -g --fetch-retries=5 --fetch-retry-mintimeout=20000 --fetch-retry-maxtimeout=120000 --fetch-timeout=300000 @siteboon/claude-code-ui

# ─── 5e. Enable ClaudeCodeUI Platform mode (no authentication required) ─
COPY scripts/enable-claudecodeui-platform-mode.sh /opt/enable-claudecodeui-platform-mode.sh
RUN chmod +x /opt/enable-claudecodeui-platform-mode.sh && \
    bash /opt/enable-claudecodeui-platform-mode.sh

# ─── 5f. 预装所有按需桌面应用 ─────────────────────────────────────────────
# 把 configs/on-demand-apps/*.json 声明的应用按 manifest 装到与 webclaw-app-launcher
# 期望一致的路径上,桌面图标首次点击就直接 exec,不再弹 zenity 安装框。
# 单个应用预装失败会软兜底,运行时 launcher 仍是 fallback。
#
# 跳过超大软件包以减少构建时间和镜像大小:
# - android-studio: ~1GB+
# - intellij: ~600-800MB (JetBrains IDE)
# - pycharm: ~600-800MB (JetBrains IDE)
# - blender: ~500MB (3D建模)
# - eclipse: ~200-300MB (IDE)
# - trae: ~200MB (AI编程工具)
# 这些应用运行时仍可通过桌面图标按需安装。
COPY scripts/preinstall-on-demand.sh /opt/preinstall-on-demand.sh
RUN chmod +x /opt/preinstall-on-demand.sh && \
    PREINSTALL_SKIP=android-studio,intellij,pycharm,blender,eclipse,trae /opt/preinstall-on-demand.sh

#docker build -t land007/webclaw_full:latest .
